FROM python:3.9-bullseye@sha256:5bd3c295ffab8b738108c7705052086d78b036078d5605dfc51e328ab758cc07

RUN apt-get update && apt-get -y install --no-install-recommends \
    festival festvox-ca-ona-hts lame git make autoconf automake libtool \
    pkg-config gcc libsonic-dev ronn kramdown libpcaudio-dev libatlas-base-dev \
    gfortran curl && \
    rm -rf /var/lib/apt/lists/*

# Pau (male) Catalan voice — pinned to commit d2eb1b4
# festvox-ca-pau-hts was only in the festcat PPA (now unreachable); these are the same files
RUN mkdir -p /usr/share/festival/voices/catalan/upc_ca_pau_hts/festvox \
             /usr/share/festival/voices/catalan/upc_ca_pau_hts/hts && \
    curl -fsSL "https://raw.githubusercontent.com/FestCat/festcat-voices/d2eb1b41239076870074ba35af3f37abe37243a4/upc_ca_pau_hts/festvox/upc_ca_pau_hts.scm" \
         -o /usr/share/festival/voices/catalan/upc_ca_pau_hts/festvox/upc_ca_pau_hts.scm && \
    curl -fsSL "https://raw.githubusercontent.com/FestCat/festcat-voices/d2eb1b41239076870074ba35af3f37abe37243a4/upc_ca_pau_hts/hts/label.feats" \
         -o /usr/share/festival/voices/catalan/upc_ca_pau_hts/hts/label.feats && \
    curl -fsSL "https://raw.githubusercontent.com/FestCat/festcat-voices/d2eb1b41239076870074ba35af3f37abe37243a4/upc_ca_pau_hts/hts/upc_ca_pau.htsvoice" \
         -o /usr/share/festival/voices/catalan/upc_ca_pau_hts/hts/upc_ca_pau.htsvoice

# espeak-ng with Catalan support — pinned to commit 9ad30a7 on ca-pr branch
RUN git clone https://github.com/projecte-aina/espeak-ng && \
    cd espeak-ng && git checkout 9ad30a756d86c46e6b68bc3e08cdcdcd9178d286 && \
    ./autogen.sh && ./configure --prefix=/usr && make && make install && \
    cd .. && rm -rf espeak-ng

# VITS with compiled monotonic_align C extension — pinned to commit 2e561ba
RUN useradd -m -u 1000 user
USER user
ENV HOME=/home/user PATH=/home/user/.local/bin:$PATH
WORKDIR /home/user/app

# Only Cython + numpy needed to compile monotonic_align; torch/scipy come from
# the app's requirements at runtime via coqui-ai/TTS. Installing the full
# VITS requirements.txt fails on Python 3.9 — numpy==1.18.5 and scipy==1.5.2
# predate Python 3.9 wheels and can't be built from source with modern pip.
RUN git clone https://github.com/jaywalnut310/vits.git && \
    cd vits && git checkout 2e561ba58618d021b5b8323d3765880f7e0ecfdb && \
    pip install --user "Cython==0.29.21" "numpy>=1.21,<1.25" && \
    cd monotonic_align && python setup.py build_ext --inplace

ENV PYTHONPATH=/home/user/app/vits
